installdirs:
	for dir in "$(DESTDIR)$(libdir)" "$(DESTDIR)$(pkgconfiglibdir)" "$(DESTDIR)$(thirdpartyincludedir)"; do \
	  test -z "$$dir" || $(MKDIR_P) "$$dir"; \
	done
